rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles: only the authenticated user can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Patrol sessions: any authenticated supervisor can read/write
    match /patrol_sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
  }
}
